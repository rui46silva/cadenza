# Copia este ficheiro para `.env` e preenche os valores.
#   cp .env.example .env

# Ligação à base de dados PostgreSQL.
# - Local:  postgresql://cadenza:cadenza@localhost:5432/cadenza?schema=public
# - Neon:   cola aqui a connection string "Pooled connection" do teu projeto Neon
#           (inclui ?sslmode=require)
DATABASE_URL="postgresql://user:password@host:5432/cadenza?schema=public"

# Ligação direta (sem pooler) à mesma base de dados, usada só pelo
# `prisma migrate deploy` durante o build. No Neon, copia a "Direct
# connection" (sem "-pooler" no hostname). Localmente podes usar o mesmo
# valor da DATABASE_URL.
DIRECT_URL="postgresql://user:password@host:5432/cadenza?schema=public"

# Segredo usado para assinar as sessões. Gera um com:
#   openssl rand -base64 32
AUTH_SECRET="muda-este-valor-por-um-secret-forte"

# URL pública do site (sem barra final), usada em SEO (sitemap, robots,
# metadados OpenGraph) e em URLs absolutos.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Quando "true", todas as rotas (exceto /coming-soon, /login, /admin e
# /api/auth) são redirecionadas para uma página "brevemente", para
# produção antes do lançamento. Deixa em branco/false para o site normal.
COMING_SOON=""

# --- Envio de email (Resend) — para a confirmação de conta ---
# Cria conta em resend.com e gera uma API key. Sem esta variável, os emails
# de confirmação são apenas escritos na consola do servidor (modo dev).
RESEND_API_KEY=""
# Remetente usado nos emails. Em produção tem de ser um domínio verificado
# no Resend; "onboarding@resend.dev" funciona só para testes.
EMAIL_FROM="Cadenza <onboarding@resend.dev>"

# --- Publicidade (Google AdSense) — OPCIONAL ---
# Deixa em branco enquanto não tiveres a conta AdSense aprovada: sem estes
# valores não aparece publicidade nem banner de cookies.
# O teu publisher id (formato ca-pub-XXXXXXXXXXXXXXXX). Assim que estiver
# definido, é também usado para carregar a CMP "Privacy & messaging" do
# Google (exigida para visitantes no EEE/Reino Unido) — ativa e configura a
# mensagem em adsense.google.com > Privacidade e mensagens.
# https://support.google.com/adsense/answer/13554116
NEXT_PUBLIC_ADSENSE_CLIENT=""
# Ids dos blocos de anúncio criados no painel do AdSense.
NEXT_PUBLIC_ADSENSE_SLOT_FEED=""
NEXT_PUBLIC_ADSENSE_SLOT_FOOTER=""
NEXT_PUBLIC_ADSENSE_SLOT_SIDEBAR=""
NEXT_PUBLIC_ADSENSE_SLOT_SIDEBAR_LEFT=""

# --- Página "brevemente" (/coming-soon) — OPCIONAL ---
# Data/hora de lançamento (formato ISO, ex: "2026-09-01T00:00:00"). Define
# para mostrar o contador de contagem decrescente; deixa em branco para
# esconder o contador.
NEXT_PUBLIC_LAUNCH_DATE=""
# Links para as redes sociais, mostrados a quem não quer dar o email. Deixa
# em branco para esconder o respetivo ícone.
NEXT_PUBLIC_INSTAGRAM_URL=""
NEXT_PUBLIC_TIKTOK_URL=""
# Número de lugares para o acesso antecipado, mostrado como barra de
# progresso para criar urgência. Deixa em branco para esconder a barra.
NEXT_PUBLIC_WAITLIST_LIMIT="200"
